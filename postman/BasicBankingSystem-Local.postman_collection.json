      "item": [
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const unique = Date.now().toString();",
                  "pm.collectionVariables.set('identityNumber', `MTC-${unique}`);",
                  "pm.collectionVariables.set('mobile', `138${unique.slice(-8)}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create customer returns 201', function () {",
                  "    pm.response.to.have.status(201);",
