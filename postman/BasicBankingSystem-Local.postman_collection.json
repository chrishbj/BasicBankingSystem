    {
      "name": "Deposits",
      "item": [
        {
          "name": "Submit Deposit",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const unique = Date.now().toString();",
                  "pm.collectionVariables.set('correlationId', `postman-correlation-${unique}`);",
                  "pm.collectionVariables.set('idempotencyKey', `postman-idempotency-${unique}`);",
                  "pm.collectionVariables.set('runnerMode', 'true');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Submit deposit returns 202', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('transactionId', json.transactionId);",
                  "pm.collectionVariables.set('pollAttempt', '0');",
                  "if (pm.collectionVariables.get('runnerMode') === 'true') {",
                  "    pm.execution.setNextRequest('Wait For Deposit Completion');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              },
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": {{depositAmount}},\n  \"currency\": \"{{currency}}\",\n  \"channel\": 1,\n  \"referenceNumber\": \"POSTMAN-REF-001\",\n  \"note\": \"Postman local test\"\n}"
            },
            "url": "{{depositBaseUrl}}/api/v1/deposits"
          }
        },
        {
          "name": "Wait For Deposit Completion",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Wait for deposit returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const status = json.status;",
                  "const attempt = Number(pm.collectionVariables.get('pollAttempt') || '0') + 1;",
                  "const maxAttempts = Number(pm.collectionVariables.get('pollMaxAttempts') || '20');",
                  "pm.collectionVariables.set('pollAttempt', String(attempt));",
                  "pm.test('Deposit does not fail during polling', function () {",
                  "    pm.expect(status).to.not.equal(5);",
                  "});",
                  "if (status === 3) {",
                  "    pm.test('Deposit reaches succeeded status', function () {",
                  "        pm.expect(status).to.equal(3);",
                  "    });",
                  "    pm.execution.setNextRequest('Get Account By Id');",
                  "} else if (status === 5) {",
                  "    pm.execution.setNextRequest(null);",
                  "} else if (attempt >= maxAttempts) {",
                  "    pm.test('Deposit completes before max polling attempts', function () {",
                  "        pm.expect.fail(`Deposit did not complete within ${maxAttempts} polling attempts. Last status: ${status}`);",
                  "    });",
                  "    pm.execution.setNextRequest(null);",
                  "} else {",
                  "    pm.execution.setNextRequest('Wait For Deposit Completion');",
                  "}",
                  "console.log(`Polling deposit attempt ${attempt}/${maxAttempts}, status=${status}`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": "{{depositBaseUrl}}/api/v1/deposits/{{transactionId}}"
          }
        },
        {
          "name": "Get Deposit By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get deposit returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": "{{depositBaseUrl}}/api/v1/deposits/{{transactionId}}"
          }
        }
      ]
